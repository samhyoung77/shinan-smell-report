rules_version = '2';

// ============================================================================
// Firestore Security Rules — anonymous public read + validated create.
// Only the `reports` collection exists. Buildings are hardcoded client-side
// (see js/buildings.js) and are NOT stored in Firestore.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /reports/{id} {

      // Public read (no auth) — the app is an anonymous community report.
      allow read: if true;

      // Schema-validated create:
      //   buildingId : must be one of the 12 known dong IDs
      //   intensity  : int in [1..3]
      //   note       : optional string ≤ 200 chars
      //   ts         : must equal request.time (server-issued serverTimestamp)
      //   clientDate : YYYY-MM-DD string (used for stats bucketing)
      // Only these five keys allowed; unknown fields rejected.
      allow create: if
        request.resource.data.keys().hasOnly(
          ['buildingId', 'intensity', 'note', 'ts', 'clientDate']
        )
        && request.resource.data.buildingId is string
        && request.resource.data.buildingId in [
             'b101', 'b102', 'b103', 'b104', 'b105',
             'b201', 'b202', 'b203', 'b204', 'b205', 'b206', 'b207'
           ]
        && request.resource.data.intensity is int
        && request.resource.data.intensity >= 1
        && request.resource.data.intensity <= 3
        && (
             !('note' in request.resource.data)
             || (
                  request.resource.data.note is string
                  && request.resource.data.note.size() <= 200
                )
           )
        && request.resource.data.ts == request.time
        && request.resource.data.clientDate is string
        && request.resource.data.clientDate.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');

      // Update never allowed (edits could mask bad-faith reports).
      allow update: if false;

      // Delete allowed within 24h of creation only.
      // Rationale: this is an anonymous app, so "owner" cannot be proven
      // via auth. Instead, the client remembers its own report IDs in
      // localStorage and only surfaces the cancel button for those.
      // The 24h server-time guard means even a leaked report ID cannot
      // be used to purge historical data — only fresh reports are removable.
      allow delete: if request.time < resource.data.ts + duration.value(24, 'h');
    }

    // Catch-all deny for any collection not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
