{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "_workspace/**",
      ".claude/**",
      "CLAUDE.md",
      "DESIGN.md",
      "FIREBASE_SETUP.md",
      "README.md",
      "firestore.rules",
      "DanJI.jpg",
      "package*.json"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css|jpg|png|svg|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      }
    ],
    "cleanUrls": true
  }
}
